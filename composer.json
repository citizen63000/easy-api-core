{
  "name": "citizen63000/easy-api-core",
  "type": "symfony-bundle",
  "description": "Symfony bundle providing core utilities for REST API development",
  "license": "MIT",
  "keywords": ["api", "rest", "symfony"],
  "authors": [
    {"name": "citizen63000"},
    {"name": "DarwinOnLine"}
  ],
  "require": {
    "php": ">=8.3",
    "doctrine/doctrine-bundle": "^2.7",
    "doctrine/orm": "^2.7|^3.0",
    "fakerphp/faker": "^1.23",
    "nelmio/api-doc-bundle": "^4.10",
    "psr/cache": "^3.0",
    "ramsey/uuid-doctrine": "^2.0",
    "symfony/console": "^6.4|^7.0|^8.0",
    "symfony/form": "^6.4|^7.0|^8.0",
    "symfony/serializer": "^6.4|^7.0|^8.0",
    "symfony/validator": "^6.4|^7.0|^8.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "@stable"
  },
  "config": {
    "discard-changes": true,
    "platform": {
      "php": "8.3"
    },
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true
    }
  },
  "autoload": {
    "psr-4": {
      "EasyApiCore\\": "Framework/"
    }
  },
  "scripts": {
    "clean-code": "PHP_CS_FIXER_IGNORE_ENV=1 php vendor/friendsofphp/php-cs-fixer/php-cs-fixer fix . --config=.php-cs --path-mode=intersection --verbose"
  }
}
